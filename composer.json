{
    "name": "dimer47/laravel-env-migrations",
    "description": "Versioned migration system for Laravel's .env file, similar to database migrations.",
    "keywords": ["laravel", "env", "migrations", "environment", "dotenv", "configuration"],
    "license": "MIT",
    "version": "1.0.1",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Dimer47\\EnvMigrations\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dimer47\\EnvMigrations\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dimer47\\EnvMigrations\\EnvMigrationServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
